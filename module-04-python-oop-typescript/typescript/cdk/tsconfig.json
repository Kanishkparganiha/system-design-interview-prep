{
  "compilerOptions": {
    "target":                 "ES2020",
    "module":                 "commonjs",
    "lib":                    ["es2020"],
    "strict":                 true,
    "noImplicitAny":          true,
    "strictNullChecks":       true,
    "esModuleInterop":        true,
    "skipLibCheck":           true,
    "inlineSourceMap":        true,
    "inlineSources":          true
  },
  "exclude": ["node_modules", "cdk.out"]
}
